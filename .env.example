# Copie para .env e preencha os valores.
# cp .env.example .env

# ============================================================
#  O QUE VOCÊ NORMALMENTE PRECISA
# ============================================================

# Chave gratuita em https://console.groq.com
GROQ_API_KEY=

# Usado pelos exemplos de API (01–05).
TARGET_API_URL=http://localhost:3000

# ============================================================
#  PERFORMANCE WEB — EDITE `tests/config/web-perf.json`
# ============================================================
# URLs, perfis, runs, aggregation, saveHtml e descoberta por sitemap
# são todos controlados por esse único arquivo. Mantenha-o commitado
# para que todo o time use o mesmo plano de testes.

# ============================================================
#  ESCAPE HATCHES (só para CI, monitoring ou testes pontuais)
# ============================================================
# As variáveis abaixo SOBRESCREVEM o JSON — use só quando precisar
# rodar algo diferente do plano commitado, sem alterar o arquivo.

# URL única (sobrescreve "urls" do JSON)
# TARGET_WEB_URL=https://outrosite.com/

# Múltiplas URLs separadas por vírgula
# TARGET_WEB_URLS=https://a.com/,https://b.com/

# Plano alternativo (outro JSON com urls/profiles/runs/...)
# WEB_PERF_CONFIG=tests/config/plans/staging.json

# Override de runs / aggregation / html
# LIGHTHOUSE_RUNS=3
# LIGHTHOUSE_AGGREGATION=median
# LIGHTHOUSE_SAVE_HTML=1

# Diretório base dos artefatos
# RESULTS_DIR=./results

# Falha o processo se métricas passarem dos limites
# WEB_PERF_STRICT=1
# WEB_PERF_MIN_SCORE=50
# WEB_PERF_MAX_LCP_MS=4000
# WEB_PERF_MAX_FCP_MS=3000
# WEB_PERF_MAX_TBT_MS=600
# WEB_PERF_MAX_TTFB_MS=600
# WEB_PERF_MAX_TTI_MS=7300
# WEB_PERF_MAX_CLS=0.25
# WEB_PERF_MAX_SPEED_INDEX_MS=5800

# Comparar com um session-summary.json anterior
# WEB_PERF_BASELINE_PATH=tests/config/web-perf.baseline.json
# WEB_PERF_REGRESSION_TOLERANCE_PCT=10
# WEB_PERF_FAIL_ON_BASELINE_REGRESSION=1
